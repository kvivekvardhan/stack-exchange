PORT=4000

# Preferred option: a full connection string
DATABASE_URL=postgresql://stackfast_app:stackfast_dev_pass@localhost:5432/stackfast

# Alternative discrete connection variables (used if DATABASE_URL is unset)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=stackfast_app
# PGPASSWORD=stackfast_dev_pass
# PGDATABASE=stackfast

# Optional SSL toggle for hosted PostgreSQL providers
# DATABASE_SSL=false
