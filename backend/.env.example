PORT=4000

# Dual-Port Setup Connection Strings
BASELINE_DATABASE_URL=postgresql://localhost:5434/stackfast
VECTOR_DATABASE_URL=postgresql://localhost:5433/stackfast

# Legacy fallback (if single connection is used)
DATABASE_URL=postgresql://localhost:5434/stackfast

# Alternative discrete connection variables
# PGHOST=localhost
# PGPORT=5434
# PGUSER=postgres
# PGPASSWORD=
# PGDATABASE=stackfast

# Optional SSL toggle for hosted PostgreSQL providers
# DATABASE_SSL=false
