 							 int setno, int setoff, int *numGroups);
 static void initialize_phase(AggState *aggstate, int newphase);
 
+/*
+ * VECTORIZED: emit aggregate rows directly from ScanState side-channel arrays.
+ *
+ * Expected output shape:
+ *   (PostTypeId, AVG(Score), COUNT(*))
+ */
+static TupleTableSlot *
+ExecVecAgg(AggState *aggstate)
+{
+	PlanState	  *outer;
+	ScanState	  *scan;
+	ExprContext   *econtext;
+	int			   g;
+
+	outer = outerPlanState(aggstate);
+	if (outer == NULL || !IsA(outer, ScanState))
+		return NULL;
+
+	scan = (ScanState *) outer;
+	econtext = aggstate->ss.ps.ps_ExprContext;
+
+	/* Drain the outer scan once so vector side-channel stats are finalized. */
+	if (!aggstate->vec_agg_drained)
+	{
+		while (ExecProcNode(outer) != NULL)
+			;
+		aggstate->vec_agg_drained = true;
+		aggstate->vec_agg_emit_index = 1;
+	}
+
+	for (;;)
+	{
+		if (aggstate->vec_agg_emit_index >= 8)
+			return NULL;
+
+		g = aggstate->vec_agg_emit_index++;
+		if (scan->vec_agg_count[g] == 0)
+			continue;
+
+		/*
+		 * Fill precomputed aggregate values for projection targetlist:
+		 *   Agg value 1: AVG(score)
+		 *   Agg value 2: COUNT(*)
+		 */
+		econtext->ecxt_aggvalues[0] = Float8GetDatum(
+			scan->vec_agg_sum[g] / (double) scan->vec_agg_count[g]);
+		econtext->ecxt_aggnulls[0] = false;
+
+		econtext->ecxt_aggvalues[1] = Int64GetDatum(scan->vec_agg_count[g]);
+		econtext->ecxt_aggnulls[1] = false;
+
+		/* Group key value visible to projection. */
+		econtext->ecxt_outertuple->tts_values[1] = Int32GetDatum(g);
+		econtext->ecxt_outertuple->tts_isnull[1] = false;
+		ExecStoreVirtualTuple(econtext->ecxt_outertuple);
+
+		return ExecProject(aggstate->ss.ps.ps_ProjInfo);
+	}
+}
+
