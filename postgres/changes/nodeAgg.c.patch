+/*
+ * VECTORIZED: verify aggregate identities/shapes:
+ *   AVG(score::int4), COUNT(*)
+ */
+static bool
+ExecVecAggMatchesAggrefs(AggState *aggstate)
+{
+	ListCell   *lc;
+	bool		seen_avg = false;
+	bool		seen_count = false;
+
+	foreach(lc, aggstate->aggs)
+	{
+		Aggref	   *aggref = lfirst_node(Aggref, lc);
+		TargetEntry *tle;
+		Var		   *v;
+		char	   *aggname;
+
+		if (aggref == NULL || !OidIsValid(aggref->aggfnoid))
+			return false;
+		if (aggref->aggdistinct != NIL || aggref->aggorder != NIL || aggref->aggfilter != NULL)
+			return false;
+		aggname = get_func_name(aggref->aggfnoid);
+		if (aggname == NULL)
+			return false;
+
+		if (aggref->aggstar)
+		{
+			if (strcmp(aggname, "count") != 0 ||
+				aggref->aggtype != INT8OID || seen_count)
+				return false;
+			seen_count = true;
+			continue;
+		}
+
+		if (list_length(aggref->args) != 1)
+			return false;
+		tle = lfirst_node(TargetEntry, aggref->args);
+		if (tle == NULL || tle->expr == NULL || !IsA(tle->expr, Var))
+			return false;
+		v = castNode(Var, tle->expr);
+		if (v->varattno != 3 || v->vartype != INT4OID)
+			return false;
+		if (strcmp(aggname, "avg") != 0 ||
+			aggref->aggtype != NUMERICOID || seen_avg)
+			return false;
+		seen_avg = true;
+	}
+
+	return seen_avg && seen_count;
+}
+
+/*
+ * VECTORIZED: emit aggregate rows directly from ScanState side-channel arrays.
+ *
+ * Expected output shape:
+ *   (PostTypeId, AVG(Score), COUNT(*))
+ */
+static TupleTableSlot *
+ExecVecAgg(AggState *aggstate)
+{
+	PlanState	  *outer;
+	Agg		  *aggnode;
+	ScanState	  *scan;
+	ExprContext  *econtext;
+	ProjectionInfo *projInfo;
+	TupleTableSlot *outer_slot;
+	TupleTableSlot *result;
+	int		   g;
+	int		   grp_attno;
+
+	outer = outerPlanState(aggstate);
+	if (outer == NULL || !IsA(outer, ScanState))
+		return NULL;
+
+	aggnode = castNode(Agg, aggstate->ss.ps.plan);
+	scan = (ScanState *) outer;
+	econtext = aggstate->ss.ps.ps_ExprContext;
+	projInfo = aggstate->ss.ps.ps_ProjInfo;
+
+	/*
+	 * Safety guards:
+	 * - only simple, non-split agg (no partial/final parallel state)
+	 * - only plain/sorted strategy (not hash/mixed)
+	 * - require scan-side arrays and projection context
+	 */
+	if (!scan->vec_active || !scan->vec_agg_enabled ||
+		scan->vec_agg_keys == NULL ||
+		scan->vec_agg_sum_i64 == NULL ||
+		scan->vec_agg_count == NULL ||
+		aggstate->aggsplit != AGGSPLIT_SIMPLE ||
+		(aggstate->aggstrategy != AGG_PLAIN &&
+		 aggstate->aggstrategy != AGG_SORTED) ||
+		econtext == NULL ||
+		projInfo == NULL ||
+		projInfo->pi_state.resultslot == NULL ||
+		aggnode == NULL ||
+		aggstate->ss.ps.qual != NULL ||
+		!ExecVecAggMatchesAggrefs(aggstate))
+		return NULL;
+
+	grp_attno = aggnode->grpColIdx[0];
+	if (grp_attno <= 0)
+		return NULL;
+
+	outer_slot = econtext->ecxt_outertuple;
+	if (outer_slot == NULL)
+		outer_slot = aggstate->ss.ps.ps_OuterTupleSlot;
+	if (outer_slot == NULL)
+		outer_slot = aggstate->ss.ss_ScanTupleSlot;
+	if (outer_slot == NULL || outer_slot->tts_tupleDescriptor == NULL)
+		return NULL;
+
+	/* Drain the outer scan once so vector side-channel stats are finalized. */
+	if (!aggstate->vec_agg_drained)
+	{
+		while (ExecProcNode(outer) != NULL)
+			CHECK_FOR_INTERRUPTS();
+		aggstate->vec_agg_drained = true;
+		aggstate->vec_agg_emit_index = 0;
+	}
+
+	for (;;)
+	{
+		if (aggstate->vec_agg_emit_index >= scan->vec_agg_ngroups)
+		{
+			aggstate->agg_done = true;
+			return NULL;
+		}
+
+		g = aggstate->vec_agg_emit_index++;
+		if (scan->vec_agg_count[g] == 0)
+			continue;
+
+		/*
+		 * Populate aggregate values for ExecProject and set the grouping
+		 * key into the outer tuple slot (input TupleDesc).
+		 */
+		MemSet(econtext->ecxt_aggvalues, 0, aggstate->numaggs * sizeof(Datum));
+		MemSet(econtext->ecxt_aggnulls, true, aggstate->numaggs * sizeof(bool));
+
+		{
+			Datum avg_sum_numeric = DirectFunctionCall1(int8_numeric, Int64GetDatum(scan->vec_agg_sum_i64[g]));
+			Datum avg_count_numeric = DirectFunctionCall1(int8_numeric, Int64GetDatum(scan->vec_agg_count[g]));
+			Datum avg_val = DirectFunctionCall2(numeric_div, avg_sum_numeric, avg_count_numeric);
+			Datum count_val = Int64GetDatum(scan->vec_agg_count[g]);
+			ListCell *lc;
+
+			foreach(lc, aggstate->aggs)
+			{
+				Aggref *aggref = lfirst_node(Aggref, lc);
+				int aggno = aggref->aggno;
+
+				if (aggno < 0 || aggno >= aggstate->numaggs)
+					return NULL;
+
+				if (aggref->aggstar)
+					econtext->ecxt_aggvalues[aggno] = count_val;
+				else
+					econtext->ecxt_aggvalues[aggno] = avg_val;
+				econtext->ecxt_aggnulls[aggno] = false;
+			}
+		}
+
+		ExecClearTuple(outer_slot);
+		MemSet(outer_slot->tts_values, 0, outer_slot->tts_tupleDescriptor->natts * sizeof(Datum));
+		MemSet(outer_slot->tts_isnull, true, outer_slot->tts_tupleDescriptor->natts * sizeof(bool));
+		outer_slot->tts_values[grp_attno - 1] = Int32GetDatum(scan->vec_agg_keys[g]);
+		outer_slot->tts_isnull[grp_attno - 1] = false;
+		ExecStoreVirtualTuple(outer_slot);
+
+		econtext->ecxt_outertuple = outer_slot;
+		econtext->ecxt_scantuple = outer_slot;
+
+		result = ExecProject(projInfo);
+		return result;
+	}
+}
