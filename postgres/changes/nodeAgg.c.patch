+/* VECTORIZED: emit aggregate output rows from scan state */
+static TupleTableSlot *
+vec_agg_emit(AggState *aggstate, ScanState *scanstate)
+{
+	TupleTableSlot *slot = aggstate->ss.ps.ps_ResultTupleSlot;
+	TupleDesc	 desc = slot->tts_tupleDescriptor;
+	int		 i;
+
+	if (desc->natts < 3)
+		return NULL;
+
+	for (i = aggstate->vec_agg_emit_index; i < VEC_AGG_MAX_GROUPS; i++)
+	{
+		int64 count = scanstate->vec_agg_count ? scanstate->vec_agg_count[i] : 0;
+
+		if (count == 0)
+			continue;
+
+		ExecClearTuple(slot);
+		memset(slot->tts_isnull, true, desc->natts * sizeof(bool));
+
+		slot->tts_values[0] = Int32GetDatum(i);
+		slot->tts_isnull[0] = false;
+		slot->tts_values[1] = Float8GetDatum(scanstate->vec_agg_sum[i] / (double) count);
+		slot->tts_isnull[1] = false;
+		slot->tts_values[2] = Int64GetDatum(count);
+		slot->tts_isnull[2] = false;
+		ExecStoreVirtualTuple(slot);
+
+		aggstate->vec_agg_emit_index = i + 1;
+		return slot;
 	}
 
 	return NULL;
