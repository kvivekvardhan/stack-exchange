+/* VECTORIZED: detect supported aggregate shape (prototype only) */
+static bool
+vec_agg_supported(AggState *aggstate, ScanState **scanstate_out)
+{
+	PlanState  *outer;
+	Agg	   *aggnode;
+	ScanState  *scan;
+
+	aggnode = (Agg *) aggstate->ss.ps.plan;
+	outer = outerPlanState(aggstate);
+	if (outer == NULL || !IsA(outer, SeqScanState))
+		return false;
+	if (aggnode->numCols != 1)
+		return false;
+	if (aggstate->numaggs != 2)
+		return false;
+	if (list_length(outer->plan->targetlist) != 2)
+		return false;
+
+	scan = &((SeqScanState *) outer)->ss;
+	*scanstate_out = scan;
+	return true;
+}
